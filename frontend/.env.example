# ===========================================
# API CONFIGURATION
# ===========================================
# Choose ONE of these options:

# OPTION 1: Same domain deployment (frontend & backend on same domain)
# If backend is at yourdomain.com/api
VITE_API_BASE_URL=/api

# OPTION 2: Subdomain deployment (API on subdomain)
# If backend is at api.yourdomain.com
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
# Backend URL for development proxy (vite.config.js)
# Used ONLY for local development with `npm run dev`
VITE_BACKEND_URL=http://localhost:5000

# Frontend port for development
VITE_PORT=5173

# ===========================================
# BUILD CONFIGURATION  
# ===========================================
# Base URL for deployment (use '/' for root deployment)
VITE_BASE_URL=/

# Site URL for SEO (canonical URL in meta tags)
# For development: leave empty or use http://localhost:5173
# For production: https://yourdomain.com
VITE_SITE_URL=http://localhost:5173

# ===========================================
# SEO CONFIGURATION
# ===========================================
# IMPORTANT: Required for proper pre-rendering and SEO
# This URL is used for canonical links and meta tags
VITE_SITE_URL=http://localhost:5173

# Port for local development (optional, defaults to 5173)
VITE_PORT=5173
