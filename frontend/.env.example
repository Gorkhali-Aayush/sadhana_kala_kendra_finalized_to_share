# ===========================================
# API CONFIGURATION
# ===========================================
# Choose ONE of these options:

# OPTION 1: Same domain deployment (frontend & backend on same domain)
# If backend is at yourdomain.com/api
VITE_API_BASE_URL=/api

# OPTION 2: Subdomain deployment (API on subdomain)
# If backend is at api.yourdomain.com
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# ===========================================
# BUILD CONFIGURATION  
# ===========================================
# Base URL for deployment (use '/' for root deployment)
VITE_BASE_URL=/
