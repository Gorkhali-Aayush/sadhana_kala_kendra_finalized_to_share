# Copy this file to .env.production and update values for your production environment
# Example: cp .env.production.example .env.production

# API Base URL - Your backend API endpoint (include /api)
# For same-domain deployment (recommended):
VITE_API_BASE_URL=/api

# For subdomain API deployment:
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# Base URL for deployment (use '/' for root deployment)
VITE_BASE_URL=/

# ===========================================
# SEO CONFIGURATION
# ===========================================
# CRITICAL for production: Must be your actual domain
# Used for canonical links, meta tags, and pre-rendered HTML
# DO NOT use localhost or 127.0.0.1 in production
VITE_SITE_URL=https://sadhanakalakendra.com.np
