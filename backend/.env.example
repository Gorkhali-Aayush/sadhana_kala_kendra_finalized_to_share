# ===========================================
# SERVER CONFIGURATION
# ===========================================
# Node environment (development, staging, production)
NODE_ENV=production

# Port for the backend server
# In cPanel: Usually assigned by Node.js Selector (default 5000)
# In Docker/local: Set to your preferred port
PORT=5000

# ===========================================
# DATABASE CONFIGURATION (MySQL)
# ===========================================
# In cPanel, usually: localhost
DB_HOST=localhost
# cPanel database username format: cpanelusername_dbuser
DB_USER=cpanelusername_dbuser
# Your database user password
DB_PASSWORD=your_secure_database_password
# cPanel database name format: cpanelusername_dbname
DB_NAME=cpanelusername_dbname
DB_PORT=3306

# ===========================================
# SECURITY
# ===========================================
# Generate a strong random string (32+ characters)
# Use: openssl rand -base64 32
JWT_SECRET=your_super_secure_jwt_secret_key_minimum_32_characters

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Your frontend domain (no trailing slash)
# CRITICAL for production: Must match your actual frontend domain
# For same-domain deployment: https://yourdomain.com
# For subdomain deployment: https://yourdomain.com (frontend domain)
# For local development: http://localhost:5173
FRONTEND_URL=https://yourdomain.com

# Optional: Additional allowed origins (comma-separated)
# Use this if you have multiple frontend domains
# ADDITIONAL_ORIGINS=https://staging.yourdomain.com,https://www.yourdomain.com

# ===========================================
# API CONFIGURATION
# ===========================================
# Optional: Your API domain (for CSP and internal references)
# Usually same as the server domain
# For same-domain: https://yourdomain.com
# For API subdomain: https://api.yourdomain.com
# API_URL=https://yourdomain.com
